# 数据库配置
DATABASE_URL=postgresql://postgres:password@localhost:5432/podcast_qa_db

# Redis配置
REDIS_URL=redis://localhost:6379

# OpenAI配置
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Elasticsearch配置
ELASTICSEARCH_URL=http://localhost:9200

# 应用配置
SECRET_KEY=your-super-secret-key-here
DEBUG=true

# API配置
MAX_DAILY_SEARCHES_FREE=3
MAX_SEARCH_RESULTS=3

# 文件上传
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads